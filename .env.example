# worca-t environment configuration template.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# --- Anthropic (LLM) ---
ANTHROPIC_API_KEY=
# Optional: override base URL when routing through a proxy gateway.
ANTHROPIC_BASE_URL=

# --- Corporate proxy ---
# If your machine already has these set in the system env, you can leave them blank here.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# --- Jira / Xray (step 1 + step 5) ---
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_XRAY_CLIENT_ID=
JIRA_XRAY_CLIENT_SECRET=
JIRA_XRAY_API_KEY=

# --- System Under Test ---
SUT_BASE_URL=http://localhost:3000
# Tip: use `--env-file path/to/.env` to load SUT-specific env vars (e.g.
# BASE_URL, credentials). Values stay in the process — never sent to agents.

# --- Misc ---
WORCA_T_DEFAULT_WORKSPACE=~/.worca-t
WORCA_T_MAX_STEP_TIMEOUT_S=1800
# Override the claude CLI binary name if your install uses a different command.
WORCA_T_CLAUDE_BIN=claude

# --- Development only ---
# Point at the worca-t source tree to pick up live edits to agents/, templates/,
# schemas/, skills/, examples/, CLAUDE.md, .mcp.json without reinstalling.
# Without this, the runner reads the frozen snapshot baked into the installed wheel.
# WORCA_T_RESOURCE_ROOT=/absolute/path/to/worca-t
