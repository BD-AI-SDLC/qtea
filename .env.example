# qtea environment configuration template.
#
# HOW TO USE
#   1. Copy this file to `.env` in the directory from which you run `qtea`
#      (typically the root of your SUT repo or the qtea repo itself).
#   2. Fill in the values relevant to your setup.
#   3. `.env` is gitignored — never commit it.
#
# Precedence: shell environment > .env > .env.local > defaults.
# qtea never overrides a var that is already set in the shell.


# ── Required ──────────────────────────────────────────────────────────────────
# qtea runs on the Bosch Model Farm (BMF). This is the only var that must be
# set for the pipeline to function.
ANTHROPIC_AUTH_TOKEN=


# ── Conditional: Jira / Xray ──────────────────────────────────────────────────
# Only needed when using Jira as the spec source (step 1) or uploading test
# cases to Xray (step 5). Skip this block entirely for file-based specs.

# JIRA_BASE_URL is only needed for the jira:KEY shorthand (full URLs are self-describing).
JIRA_BASE_URL=
# Atlassian Cloud (*.atlassian.net) — Basic auth: set JIRA_EMAIL + JIRA_API_TOKEN
JIRA_EMAIL=
JIRA_API_TOKEN=
# Jira Server / Data Center (on-prem) — Bearer auth: set JIRA_PAT instead of the above two
JIRA_PAT=
# Auth-scheme override: "basic" | "pat" | "bearer". Inferred automatically when omitted.
JIRA_AUTH_TYPE=
# Fallback Jira project key used by Xray upload (step 5) when the spec does not carry one.
JIRA_PROJECT_KEY=
JIRA_XRAY_CLIENT_ID=
JIRA_XRAY_CLIENT_SECRET=
JIRA_XRAY_API_KEY=


# ── Conditional: Azure DevOps ─────────────────────────────────────────────────
# Only needed when using Azure DevOps as the spec source (step 1) or for
# variable-group injection (step 6).
AZDO_ORG=
AZDO_PROJECT=
AZDO_PAT=
AZDO_VARIABLE_GROUP=


# ── Conditional: System Under Test ───────────────────────────────────────────
# Needed for live browser exploration (step 7) and JIT locator resolution (step 9).
SUT_BASE_URL=http://localhost:3000
# Path to a Playwright storage-state file (session cookies / local-storage) for authenticated runs.
QTEA_STORAGE_STATE=
# Path to a dev-supplied locator file (JSON) to seed JIT resolution without LLM calls.
QTEA_DEV_LOCATORS=
# Tip: use `--env-file path/to/.env` to load SUT-specific env vars (e.g.
# credentials). Values stay in the process — never sent to agents.


# ── Optional: LLM transport ───────────────────────────────────────────────────
# Alternative transports (non-BMF). Leave blank if using ANTHROPIC_AUTH_TOKEN above.

# Direct Anthropic API (non-BMF environments only).
ANTHROPIC_API_KEY=
# Generic proxy base URL.
ANTHROPIC_BASE_URL=
# Vertex AI opt-in (Claude Code ↔ Vertex transport). Set to "1" to enable.
CLAUDE_CODE_USE_VERTEX=
CLAUDE_CODE_SKIP_VERTEX_AUTH=    # set to "1" if your proxy handles auth
# Vertex-compatible proxy: set all three.
ANTHROPIC_VERTEX_BASE_URL=
ANTHROPIC_VERTEX_PROJECT_ID=     # proxy often ignores this; "_" works as a placeholder
CLOUD_ML_REGION=                 # proxy often ignores this; "us-east5" works as a placeholder
# Extra HTTP headers forwarded to every claude subprocess (e.g. BMF sticky-session header).
# Format: JSON object string, e.g. '{"X-BMF-Session": "my-session-id"}'
ANTHROPIC_CUSTOM_HEADERS=
# Disable prompt caching for all claude subprocess calls (set to "1").
DISABLE_PROMPT_CACHING=


# ── Optional: Corporate proxy ─────────────────────────────────────────────────
# If your machine already has these set in the system env, leave them blank here.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1


# ── Optional: Workspace & runtime knobs ──────────────────────────────────────
QTEA_DEFAULT_WORKSPACE=~/.qtea
QTEA_MAX_STEP_TIMEOUT_S=1800
# Override the claude CLI binary name if your install uses a different command.
QTEA_CLAUDE_BIN=claude
# Set to "1" in CI to skip LLM-based JIT locator resolution (zero-LLM-spend mode).
QTEA_NO_LLM_RESOLVE=
# Overlay auto-dismiss behaviour: "auto" (default) | "skip" | "fail".
QTEA_OVERLAY_HANDLING=
# Multiply all Playwright timeouts by this factor (e.g. "2" for slow CI). Default: 1.
QTEA_INFLATE_TIMEOUTS=
# Default Playwright action/navigation timeout in ms. Default: 30000.
QTEA_DEFAULT_TIMEOUT_MS=


# ── Development only ──────────────────────────────────────────────────────────
# Point at the qtea source tree to pick up live edits to agents/, templates/,
# schemas/, skills/, examples/, CLAUDE.md, .mcp.json without reinstalling.
# Without this, the runner reads the frozen snapshot baked into the installed wheel.
# QTEA_RESOURCE_ROOT=/absolute/path/to/qtea
