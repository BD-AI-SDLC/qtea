{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worca-t/schemas/plan.schema.json",
  "title": "TestPlan",
  "type": "object",
  "required": ["title", "phases"],
  "additionalProperties": true,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "overview": { "type": "string" },
    "commands": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "phase_summary": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["number", "title"],
        "properties": {
          "number": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "overview": { "type": "string" },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["title"],
              "properties": {
                "title": { "type": "string" },
                "source": { "type": ["string", "null"] },
                "test_file": { "type": ["string", "null"] },
                "test_class": { "type": ["string", "null"] },
                "methods": { "type": "array", "items": { "type": "string" } },
                "raw": { "type": "string" }
              }
            }
          },
          "success_criteria": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "test_cases": {
      "type": "array",
      "items": { "$ref": "#/$defs/planTestCase" }
    },
    "acceptance_criteria_structured": {
      "type": "array",
      "items": { "$ref": "#/$defs/acceptanceCriterion" }
    },
    "coverage_notes": {
      "type": "array",
      "items": { "$ref": "#/$defs/coverageNote" }
    }
  },
  "$defs": {
    "planTestCase": {
      "type": "object",
      "required": ["id", "title", "priority", "req_id", "ac_ids"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "pattern": "^TC-[A-Za-z0-9][A-Za-z0-9\\-_]*$" },
        "title": { "type": "string", "minLength": 1 },
        "type": { "type": ["string", "null"] },
        "priority": { "type": "string", "enum": ["P0", "P1", "P2", "P3", "UNKNOWN"] },
        "req_id": { "type": "string" },
        "ac_ids": { "type": "array", "items": { "type": "string" } },
        "ec_ids": { "type": "array", "items": { "type": "string" } },
        "nfr_ids": { "type": "array", "items": { "type": "string" } },
        "automation": { "type": "string", "enum": ["automation", "manual", "needs_investigation", "UNKNOWN"] },
        "phase": { "type": ["integer", "null"] },
        "parametrized_over": { "type": "array", "items": { "type": "string" } }
      }
    },
    "acceptanceCriterion": {
      "type": "object",
      "required": ["id", "text"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "pattern": "^AC-[A-Za-z0-9][A-Za-z0-9\\-_]*$" },
        "text": { "type": "string", "minLength": 1 },
        "given": { "type": ["string", "null"] },
        "when": { "type": ["string", "null"] },
        "then": { "type": ["string", "null"] },
        "priority": { "type": "string", "enum": ["P0", "P1", "P2", "P3", "UNKNOWN"] },
        "automation": { "type": "string", "enum": ["AUTOMATABLE", "MANUAL_ONLY", "NEEDS_INVESTIGATION", "UNKNOWN"] },
        "user_flow": { "type": ["string", "null"] },
        "requires_tc": { "type": "boolean" },
        "promoted_from_nfr": { "type": "boolean" }
      }
    },
    "coverageNote": {
      "type": "object",
      "required": ["item_id", "reason", "resolution"],
      "additionalProperties": true,
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "reason": { "type": "string" },
        "resolution": { "type": "string", "enum": ["dropped", "scope_excluded", "accepted_risk", "legacy_assumption"] }
      }
    }
  }
}
