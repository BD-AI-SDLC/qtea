{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worca-t/schemas/locator-resolution.schema.json",
  "title": "LocatorResolution",
  "type": "object",
  "required": ["resolutions"],
  "additionalProperties": true,
  "properties": {
    "base_url": { "type": ["string", "null"] },
    "resolutions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["test_id", "items"],
        "properties": {
          "test_id": { "type": "string" },
          "file": { "type": ["string", "null"] },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["tbd", "replacement", "strategy"],
              "properties": {
                "tbd": { "type": "string", "description": "exact TBD token replaced" },
                "replacement": { "type": "string" },
                "strategy": {
                  "type": "string",
                  "enum": [
                    "id",
                    "data-testid",
                    "role",
                    "label",
                    "text",
                    "placeholder",
                    "css"
                  ]
                },
                "line": { "type": ["integer", "null"] },
                "confidence": {
                  "type": ["number", "null"],
                  "minimum": 0,
                  "maximum": 1
                },
                "applied": { "type": "boolean" },
                "skip_reason": { "type": ["string", "null"] }
              }
            }
          }
        }
      }
    },
    "totals": {
      "type": "object",
      "properties": {
        "tests_with_tbd": { "type": "integer" },
        "items": { "type": "integer" },
        "applied": { "type": "integer" },
        "skipped": { "type": "integer" }
      }
    }
  }
}
