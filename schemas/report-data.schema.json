{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qtea/schemas/report-data.schema.json",
  "title": "ReportData",
  "type": "object",
  "required": ["run_id", "generated_at", "run_results", "bug_reports", "summary"],
  "additionalProperties": false,
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string" },
    "plan": { "type": ["object", "null"] },
    "strategy": { "type": ["object", "null"] },
    "run_results": {
      "type": "object",
      "required": ["framework", "command", "started_at", "finished_at", "results"],
      "additionalProperties": true,
      "properties": {
        "framework": { "type": "string" },
        "command": { "type": "string" },
        "started_at": { "type": "string" },
        "finished_at": { "type": "string" },
        "results": { "type": "array" }
      }
    },
    "bug_reports": {
      "type": "object",
      "required": ["run_id", "generated_at", "summary", "bugs"],
      "additionalProperties": true,
      "properties": {
        "run_id": { "type": "string" },
        "generated_at": { "type": "string" },
        "summary": { "type": "object" },
        "bugs": { "type": "array" }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_tests", "passed", "failed", "skipped", "errors", "total_bugs", "pass_rate"],
      "properties": {
        "total_tests": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "errors": { "type": "integer", "minimum": 0 },
        "infrastructure_errors": { "type": "integer", "minimum": 0 },
        "total_bugs": { "type": "integer", "minimum": 0 },
        "duration_s": { "type": ["number", "null"], "minimum": 0 },
        "pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "pipeline_duration_s": { "type": "number", "minimum": 0 },
        "total_tokens_input": { "type": "integer", "minimum": 0 },
        "total_tokens_output": { "type": "integer", "minimum": 0 },
        "total_tokens_cache_creation": { "type": "integer", "minimum": 0 },
        "total_tokens_cache_read": { "type": "integer", "minimum": 0 },
        "total_cost_usd": { "type": "number", "minimum": 0 },
        "total_agent_calls": { "type": "integer", "minimum": 0 }
      }
    },
    "steps_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "name", "status"],
        "additionalProperties": false,
        "properties": {
          "step": { "type": "integer", "minimum": 1 },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "duration_s": { "type": ["number", "null"], "minimum": 0 },
          "tokens_input": { "type": "integer", "minimum": 0 },
          "tokens_output": { "type": "integer", "minimum": 0 },
          "tokens_cache_creation": { "type": "integer", "minimum": 0 },
          "tokens_cache_read": { "type": "integer", "minimum": 0 },
          "cost_usd": { "type": "number", "minimum": 0 },
          "agent_calls": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "auxiliary_summary": {
      "type": "array",
      "description": "Per-agent rows for the debug / critical-thinking / principal-software-engineer chain that fires on retry exhaustion. One entry per agent invocation; the parent step's cost cell no longer bundles these.",
      "items": {
        "type": "object",
        "required": ["step", "agent", "phase", "status"],
        "additionalProperties": false,
        "properties": {
          "step": { "type": "integer", "minimum": 1 },
          "agent": { "type": "string" },
          "phase": { "type": "string", "enum": ["debug", "critical_thinking", "principal_engineer"] },
          "status": { "type": "string" },
          "duration_s": { "type": ["number", "null"], "minimum": 0 },
          "tokens_input": { "type": "integer", "minimum": 0 },
          "tokens_output": { "type": "integer", "minimum": 0 },
          "tokens_cache_creation": { "type": "integer", "minimum": 0 },
          "tokens_cache_read": { "type": "integer", "minimum": 0 },
          "cost_usd": { "type": "number", "minimum": 0 },
          "agent_calls": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
