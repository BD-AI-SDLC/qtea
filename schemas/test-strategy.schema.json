{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qtea/schemas/test-strategy.schema.json",
  "title": "TestStrategy",
  "type": "object",
  "required": ["title", "test_cases"],
  "additionalProperties": true,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "scope": { "type": ["string", "null"] },
    "test_cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "pattern": "^TC-[A-Za-z0-9\\-_]+$" },
          "title": { "type": "string" },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2", "P3", "UNKNOWN"] },
          "type": { "type": ["string", "null"] },
          "preconditions": { "type": "array", "items": { "type": "string" } },
          "steps": { "type": "array", "items": { "type": "string" } },
          "expected": { "type": ["string", "null"] },
          "tags": { "type": "array", "items": { "type": "string" } },
          "raw": { "type": "string" },
          "req_id": { "type": "string" },
          "ac_ids": { "type": "array", "items": { "type": "string" } },
          "ec_ids": { "type": "array", "items": { "type": "string" } },
          "nfr_ids": { "type": "array", "items": { "type": "string" } },
          "derived_from": { "type": "array", "items": { "type": "string" } },
          "automation_type": {
            "type": "string",
            "enum": ["ui", "api", "integration", "unit", "performance", "accessibility", "contract", "visual", "manual", "UNKNOWN"]
          }
        }
      }
    },
    "coverage_notes": {
      "type": "array",
      "items": { "$ref": "#/$defs/coverageNote" }
    }
  },
  "$defs": {
    "coverageNote": {
      "type": "object",
      "required": ["item_id", "reason", "resolution"],
      "additionalProperties": true,
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "reason": { "type": "string" },
        "resolution": { "type": "string", "enum": ["dropped", "scope_excluded", "accepted_risk", "legacy_assumption"] }
      }
    }
  }
}
